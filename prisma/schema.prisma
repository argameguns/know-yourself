// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Test {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  category      String
  description   String
  scaleInfo     Json
  goalTags      String
  questionCount Int
  createdAt     DateTime @default(now())

  attempts      Attempt[]
}

model Attempt {
  id        String   @id @default(cuid())
  anonId    String
  testId    String
  test      Test     @relation(fields: [testId], references: [id])
  answers   Json
  result    Json
  createdAt DateTime @default(now())

  @@index([anonId])
}

model OnboardingResponse {
  id         String   @id @default(cuid())
  anonId     String
  answers    Json
  goalScores Json
  createdAt  DateTime @default(now())

  @@index([anonId])
}
